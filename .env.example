#### Copy this file to .env and fill in your values: cp .env.example .env
#### Comment out or delete any unused entries.

##### SYSTEM
PUID=
PGID=
TZ=
DOMAINNAME=
COMPOSE_PROJECT_NAME=
# Host-specific group ID (Synology example shown). Dockhand's group_add reuses PGID.
PLEX_VIDEO_GID=937    # videodriver group, for Plex HW transcoding (group_add)

##### VOLUMES
APPDIR=/volume1/docker/apps
DOCKERDIR=/volume1/docker
DATADIR=/volume1/data
PLEXLOGS=/volume1/docker/apps/plex/Library/Application Support/Plex Media Server/Logs

##### ADDRESSES
# IPs Traefik trusts for forwarded headers (compose reads $TRUSTED_IPS)
TRUSTED_IPS=
# IPs that are considered local (used by the crowdsec bouncer plugin)
LOCAL_IPS=
# CLOUDFLARE_IPS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

##### VPN (Gluetun / WireGuard)
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=

##### CROWDSEC
# Bouncer LAPI key shared between the crowdsec container and the Traefik bouncer plugin
CROWDSEC=

##### LOGINS/API
# PLEX_TOKEN=
CF_EMAIL=
# Cloudflare scoped API token (Zone:DNS:Edit on your zone) — used by Traefik ACME DNS-01
CF_DNS_API_TOKEN=
# CF_API_KEY= # legacy global key; no longer used by compose.yaml (kept for reference)
PROWLARR_API_KEY=
RADARR_API_KEY=
SONARR_API_KEY=
SABNZBD_API_KEY=
TAUTULLI_API_KEY=
SEERR_API_KEY=
# NOTE: the notifiarr service reads its config from its own config dir
# ($APPDIR/notifiarr), NOT from this env var. Kept here for reference only.
NOTIFIARR=

##### NOTIFICATIONS
## Pullio=Auto update containers | Discord=notifications
PULLIO=
DISCORD=

## Vaultwarden
# NOTE: the vaultwarden service in compose.yaml does NOT read this var. To enable
# the admin page, add `ADMIN_TOKEN=$ADMIN_TOKEN` to the vaultwarden service's
# environment block (or set it in the container's own config). Setting it here alone does nothing.
ADMIN_TOKEN=

## GoogleAuth
# NOTE: traefik-forward-auth (the `auth` service) reads its OAuth config from the
# mounted file at $APPDIR/auth, NOT from these env vars. They are kept here for
# reference only — setting them in .env has no effect unless you wire them into that config.
GOOGLEID=
GOOGLESECRET=
SECRET=
WHITELIST=
